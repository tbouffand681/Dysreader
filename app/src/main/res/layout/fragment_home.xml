<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Dégradé de fond -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Logo + Titre ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="48dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    app:cardCornerRadius="44dp"
                    app:cardBackgroundColor="@color/primary"
                    app:cardElevation="12dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_menu_book"
                        android:padding="20dp"
                        android:tint="@android:color/white"
                        android:contentDescription="Logo DyslexiRead" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DyslexiRead"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lisez mieux, en police OpenDyslexic"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:alpha="0.65" />

            </LinearLayout>

            <!-- ── Bouton Caméra ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_camera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:strokeColor="#4D2D7DD2"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="#1A2D7DD2"
                app:cardElevation="2dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <!-- Icône -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="14dp"
                        app:cardBackgroundColor="@color/color_camera"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_camera"
                            android:padding="13dp"
                            android:tint="@android:color/white"
                            android:contentDescription="Caméra" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Texte -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Photographier un texte"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_camera" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pointez sur n'importe quel document"
                            android:textSize="13sp"
                            android:textColor="@color/color_camera"
                            android:alpha="0.75"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/color_camera"
                        android:alpha="0.5"
                        android:contentDescription="Ouvrir" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Note "hors-ligne" ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Tout fonctionne hors-ligne — aucune donnée n'est envoyée"
                android:textSize="12sp"
                android:gravity="center"
                android:alpha="0.5"
                android:paddingTop="24dp"
                android:paddingBottom="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Overlay chargement ── -->
    <View
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:id="@+id/progress_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp" />

                <TextView
                    android:id="@+id/tv_loading_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyse en cours…"
                    android:textSize="15sp"
                    android:layout_marginTop="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
