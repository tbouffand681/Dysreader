<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Zone de lecture -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="220dp"
        android:background="#FFF8F0">

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:textSize="20sp"
            android:lineSpacingMultiplier="1.8"
            android:letterSpacing="0.06"
            android:textIsSelectable="true"
            android:textColor="#1A1A1A"
            android:text="Chargez un document pour commencer la lecture." />
    </ScrollView>

    <!-- Barre TTS fixe en bas -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Langue TTS -->
            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_fr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇫🇷 Français"
                    app:chipBackgroundColor="@color/chip_selector"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_en"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇺🇸 English"
                    app:chipBackgroundColor="@color/chip_selector"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_it"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇮🇹 Italiano"
                    app:chipBackgroundColor="@color/chip_selector"
                    style="@style/Widget.Material3.Chip.Filter" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Vitesse -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_speed" android:layout_marginEnd="4dp" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_speed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0.2"
                    android:valueTo="1.0"
                    android:stepSize="0.1"
                    android:value="0.8" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_music_note" android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_pitch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0.5"
                    android:valueTo="2.0"
                    android:stepSize="0.25"
                    android:value="1.0" />
            </LinearLayout>

            <!-- Boutons Play/Stop + état -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_stop"
                    android:layout_marginEnd="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:icon="@drawable/ic_play"
                    app:iconSize="32dp" />

                <TextView
                    android:id="@+id/tv_tts_state"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="🔇 Arrêt"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
